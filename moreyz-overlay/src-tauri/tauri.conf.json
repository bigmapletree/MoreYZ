{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "moreyz-overlay",
  "version": "0.1.0",
  "identifier": "com.mptree.moreyz-overlay",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MoreYZ Overlay",
        "width": 400,
        "height": 300,
        "x": 100,
        "y": 100,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true
      },
      {
        "label": "settings",
        "title": "MoreYZ 设置",
        "width": 600,
        "height": 500,
        "visible": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
